{
  "rules": {
    ".read": false,
    ".write": false,

    "profiles": {
      ".read": "auth != null",
      "$uid": {
        ".write": "auth != null && (auth.uid === $uid || root.child('profiles').child(auth.uid).child('role').val() === 'admin')",
        "role":        { ".write": "auth != null && root.child('profiles').child(auth.uid).child('role').val() === 'admin'" },
        "permissions": { ".write": "auth != null && root.child('profiles').child(auth.uid).child('role').val() === 'admin'" },
        "is_active":   { ".write": "auth != null && root.child('profiles').child(auth.uid).child('role').val() === 'admin'" },
        "email":       { ".write": "auth != null && root.child('profiles').child(auth.uid).child('role').val() === 'admin'" }
      }
    },

    "app_data": {
      ".read":  "auth != null && root.child('profiles').child(auth.uid).child('is_active').val() !== false",
      ".write": "auth != null && root.child('profiles').child(auth.uid).child('is_active').val() !== false"
    },

    "signatures": {
      ".read":  "auth != null",
      ".write": "auth != null && root.child('profiles').child(auth.uid).child('is_active').val() !== false"
    },

    "counters": {
      ".read":  "auth != null",
      ".write": "auth != null && root.child('profiles').child(auth.uid).child('is_active').val() !== false"
    },

    "audit_log": {
      ".read": "auth != null",
      "$pushId": {
        ".write": "auth != null && !data.exists()"
      }
    },

    "activity_log": {
      ".read": "auth != null",
      "$pushId": {
        ".write": "auth != null && !data.exists()"
      }
    },

    "sessions": {
      "$uid": {
        ".read":  "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },

    "error_log": {
      ".read": "auth != null && root.child('profiles').child(auth.uid).child('role').val() === 'admin'",
      "$pushId": {
        ".write": "auth != null && !data.exists()",
        ".validate": "newData.hasChildren(['version','context','timestamp'])"
      }
    },

    "backups": {
      "$uid": {
        ".read":  "auth != null && (auth.uid === $uid || root.child('profiles').child(auth.uid).child('role').val() === 'admin')",
        ".write": "auth != null && auth.uid === $uid",
        "$dayKey": {
          ".validate": "newData.hasChildren(['data','meta'])"
        }
      }
    }
  }
}
